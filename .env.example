# Gemini AI – one var works for both client and server
NEXT_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here

# Backend URL for resume/API calls (Django, etc.)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Google Cloud Storage – used by the portfolio video signed-URL upload flow
# (images <=4.5MB go through the Django backend; videos go directly to GCS)
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_CLOUD_STORAGE_BUCKET=
# Full service-account JSON (may be raw JSON or escaped JSON string). Server-only, never exposed to the client.
GOOGLE_CLOUD_CREDENTIALS=

# ADK Python agent server (Unibot) — separate from Django. Default in code is 8000;
# use 8001 when Django already occupies 8000. Next.js proxies chat via /api/run_sse.
ADK_BACKEND_URL=http://127.0.0.1:8001
